# ===========================================
# Supabase
# ===========================================
# Option A (Shared Barcelos DB): Use the shared project URL/keys
# Option B (Standalone): Create a new Supabase project and use its URL/keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# WorkOS Authentication
# ===========================================
WORKOS_API_KEY=sk_live_...
WORKOS_CLIENT_ID=client_...

# Redirect URI after WorkOS auth callback
# Update the port to match your app's dev port
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# App Configuration
# ===========================================
# Set to the table prefix for shared DB mode (e.g., "xx_")
# Leave empty for standalone mode
TABLE_PREFIX=

# ===========================================
# Rate Limiting (optional — Upstash Redis)
# ===========================================
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ===========================================
# Email (optional — Resend)
# ===========================================
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# Error Tracking (optional — Sentry)
# ===========================================
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# ===========================================
# File Upload (optional — S3-compatible storage)
# ===========================================
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT=https://your-endpoint.com

# ===========================================
# Cron Jobs (optional — Vercel Cron)
# ===========================================
# CRON_SECRET=your-cron-secret
